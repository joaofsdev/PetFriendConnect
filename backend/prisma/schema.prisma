// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TipoUsuario {
  DONO
  CUIDADOR
  ADMIN
}

enum StatusReserva {
  PENDENTE
  CONFIRMADA
  CANCELADA
  CONCLUIDA
}

model Usuario {
  id                Int           @id @default(autoincrement())
  nome              String
  email             String        @unique
  senha             String
  tipo              TipoUsuario
  telefone          String?
  endereco          String?
  descricao         String?       @db.LongText
  fotoPerfil        String?
  notificacoesEmail Boolean       @default(true)
  notificacoesSms   Boolean       @default(false)
  resetSenhaTokenHash String?     @unique
  resetSenhaExpiraEm DateTime?
  ativo             Boolean       @default(true)
  dataCriacao       DateTime      @default(now())
  dataAtualizacao   DateTime      @updatedAt

  // Relacionamentos
  pets              Pet[]
  servicosCriados   Servico[]
  agendas           Agenda[]
  reservasFeitas    Reserva[]     @relation("ReservasFeitas")
  reservasRecebidas Reserva[]     @relation("ReservasRecebidas")
  logs              Log[]
  denunciasFeitas   Denuncia[]    @relation("DenunciasFeitas")
  denunciasRecebidas Denuncia[]   @relation("DenunciasRecebidas")

  @@index([email])
  @@index([tipo])
  @@index([resetSenhaExpiraEm])
}

model Pet {
  id                Int           @id @default(autoincrement())
  nome              String
  raca              String
  idade             Int?
  descricao         String?       @db.LongText
  fotoPet           String?
  donoId            Int
  dataCriacao       DateTime      @default(now())
  dataAtualizacao   DateTime      @updatedAt

  // Relacionamentos
  dono              Usuario       @relation(fields: [donoId], references: [id], onDelete: Cascade)
  reservas          Reserva[]

  @@index([donoId])
}

model Servico {
  id                Int           @id @default(autoincrement())
  nome              String
  descricao         String?       @db.LongText
  preco             Decimal       @db.Decimal(10, 2)
  duracao           Int           // em minutos
  cuidadorId        Int
  ativo             Boolean       @default(true)
  dataCriacao       DateTime      @default(now())
  dataAtualizacao   DateTime      @updatedAt

  // Relacionamentos
  cuidador          Usuario       @relation(fields: [cuidadorId], references: [id], onDelete: Cascade)
  agendas           Agenda[]
  reservas          Reserva[]

  @@index([cuidadorId])
}

model Agenda {
  id                Int           @id @default(autoincrement())
  cuidadorId        Int
  servicoId         Int
  data              DateTime
  disponivel        Boolean       @default(true)
  reservaId         Int?
  dataCriacao       DateTime      @default(now())
  dataAtualizacao   DateTime      @updatedAt

  // Relacionamentos
  cuidador          Usuario       @relation(fields: [cuidadorId], references: [id], onDelete: Cascade)
  servico           Servico       @relation(fields: [servicoId], references: [id], onDelete: Cascade)
  reservas          Reserva[]

  @@index([cuidadorId, data, disponivel])
}

model Reserva {
  id                Int           @id @default(autoincrement())
  agendaId          Int
  donoId            Int
  cuidadorId        Int
  petId             Int
  servicoId         Int
  status            StatusReserva @default(PENDENTE)
  dataReserva       DateTime      @default(now())
  dataAtualizacao   DateTime      @updatedAt

  // Relacionamentos
  agenda            Agenda        @relation(fields: [agendaId], references: [id], onDelete: Cascade)
  dono              Usuario       @relation("ReservasFeitas", fields: [donoId], references: [id], onDelete: Cascade)
  cuidador          Usuario       @relation("ReservasRecebidas", fields: [cuidadorId], references: [id], onDelete: Cascade)
  pet               Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  servico           Servico       @relation(fields: [servicoId], references: [id], onDelete: Cascade)

  @@index([agendaId])
  @@index([agendaId, status])
  @@index([donoId])
  @@index([cuidadorId])
  @@index([petId])
  @@index([status])
}

model Log {
  id                Int           @id @default(autoincrement())
  usuarioId         Int
  acao              String
  descricao         String?       @db.LongText
  dataLog           DateTime      @default(now())

  // Relacionamentos
  usuario           Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([dataLog])
}

enum StatusDenuncia {
  PENDENTE
  EM_ANALISE
  RESOLVIDA
  REJEITADA
}

model Denuncia {
  id                Int             @id @default(autoincrement())
  denuncianteId     Int
  denunciadoId      Int
  motivo            String
  descricao         String?         @db.LongText
  status            StatusDenuncia  @default(PENDENTE)
  resolucao         String?         @db.LongText
  dataCriacao       DateTime        @default(now())
  dataAtualizacao   DateTime        @updatedAt

  // Relacionamentos
  denunciante       Usuario         @relation("DenunciasFeitas", fields: [denuncianteId], references: [id], onDelete: Cascade)
  denunciado        Usuario         @relation("DenunciasRecebidas", fields: [denunciadoId], references: [id], onDelete: Cascade)

  @@index([denuncianteId])
  @@index([denunciadoId])
  @@index([status])
}

model Configuracao {
  id                Int           @id @default(autoincrement())
  chave             String        @unique
  valor             String
  descricao         String?
  dataAtualizacao   DateTime      @updatedAt

  @@index([chave])
}
